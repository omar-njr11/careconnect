datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  caregiver
  nurse
  partner
  ops
}

enum Verdict {
  monitor
  call_nurse
  er
}

enum EntryType {
  symptom
  medication
  general
}

enum ConsentType {
  hipaa
  tos
  privacy
}

model User {
  id               String                  @id @default(cuid())
  email            String                  @unique
  password         String
  name             String
  role             Role
  partnerAgencyId  String?
  partnerAgency    PartnerAgency?          @relation(fields: [partnerAgencyId], references: [id])
  familyId         String?                 @unique
  family           Family?                 @relation("FamilyCaregiver", fields: [familyId], references: [id])
  consentRecords   ConsentRecord[]
  nurseAssignments FamilyNurseAssignment[]
}

model Family {
  id               String                  @id @default(cuid())
  address          String
  createdAt        DateTime                @default(now())
  caregiver        User?                   @relation("FamilyCaregiver")
  triageSessions   TriageSession[]
  careLogEntries   CareLogEntry[]
  messages         Message[]
  weeklySummaries  WeeklySummary[]
  careProfile      CareProfile?
  nurseAssignments FamilyNurseAssignment[]
  members          FamilyMember[]
}

model FamilyMember {
  id       String @id @default(cuid())
  name     String
  familyId String
  family   Family @relation(fields: [familyId], references: [id])
}

model PartnerAgency {
  id                         String                  @id @default(cuid())
  legalName                  String
  contractStatus             String
  liabilityCoverageConfirmed Boolean
  users                      User[]
  nurseAssignments           FamilyNurseAssignment[]
}

model FamilyNurseAssignment {
  id              String        @id @default(cuid())
  familyId        String
  family          Family        @relation(fields: [familyId], references: [id])
  nurseId         String
  nurse           User          @relation(fields: [nurseId], references: [id])
  partnerAgencyId String
  partnerAgency   PartnerAgency @relation(fields: [partnerAgencyId], references: [id])
  status          String        @default("active")
  assignedAt      DateTime      @default(now())
}

model TriageSession {
  id                String   @id @default(cuid())
  familyId          String
  caregiverId       String
  symptomCategoryId String
  answers           Json
  verdict           Verdict
  triggeredRuleId   String?
  treeVersion       String
  createdAt         DateTime @default(now())
  routedToNurseId   String?
  family            Family   @relation(fields: [familyId], references: [id])
}

model CareLogEntry {
  id                    String    @id @default(cuid())
  familyId              String
  caregiverId           String
  entryType             EntryType
  content               String
  createdAt             DateTime  @default(now())
  acknowledgedByNurseId String?
  acknowledgedAt        DateTime?
  family                Family    @relation(fields: [familyId], references: [id])
}

model Message {
  id         String    @id @default(cuid())
  familyId   String
  senderId   String
  senderRole Role
  content    String
  createdAt  DateTime  @default(now())
  readAt     DateTime?
  family     Family    @relation(fields: [familyId], references: [id])
}

model WeeklySummary {
  id               String   @id @default(cuid())
  familyId         String
  weekStart        DateTime
  generatedContent String
  sharedWith       String[]
  family           Family   @relation(fields: [familyId], references: [id])
}

model CareProfile {
  id                String   @id @default(cuid())
  familyId          String   @unique
  chronicConditions String[]
  allergies         String[]
  medications       String[]
  family            Family   @relation(fields: [familyId], references: [id])
}

model ConsentRecord {
  id          String      @id @default(cuid())
  userId      String
  consentType ConsentType
  version     String
  grantedAt   DateTime    @default(now())
  user        User        @relation(fields: [userId], references: [id])
}

model AuditLogEntry {
  id           String   @id @default(cuid())
  actorId      String
  actorRole    Role
  action       String
  targetEntity String
  targetId     String
  timestamp    DateTime @default(now())
}
